          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT sensor_type, COUNT(*) AS readings_count\nFROM sensor_readings\nWHERE $__timeFilter(received_at)\nGROUP BY sensor_type\nORDER BY readings_count DESC;",
          "refId": "A"
        }
      ],
      "title": "Readings by Sensor Type",
