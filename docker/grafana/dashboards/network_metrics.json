      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-road-monitoring"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  SUM((\n    pg_column_size(payload)\n    + pg_column_size(metadata)\n    + COALESCE(length(sensor_id), 0)\n    + COALESCE(length(device_id), 0)\n    + COALESCE(length(sensor_type), 0)\n  )::numeric) AS approx_throughput_bytes\nFROM sensor_readings\nWHERE $__timeFilter(created_at)\nGROUP BY time\nORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "Approximate Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres-road-monitoring"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-road-monitoring"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH per_sensor AS (\n  SELECT sensor_id,\n         MIN(received_at) AS first_seen,\n         MAX(received_at) AS last_seen,\n         MAX(COALESCE(NULLIF(metadata ->> 'sampling_interval_sec', '')::int, 2)) AS sampling_interval_sec,\n         COUNT(*) AS actual_count\n  FROM sensor_readings\n  WHERE $__timeFilter(received_at)\n  GROUP BY sensor_id\n), expected AS (\n  SELECT sensor_id,\n         actual_count,\n         GREATEST(\n           1,\n           FLOOR(EXTRACT(EPOCH FROM (last_seen - first_seen)) / NULLIF(sampling_interval_sec, 0)) + 1\n         )::numeric AS expected_count\n  FROM per_sensor\n)\nSELECT ROUND(\n         CASE\n           WHEN COALESCE(SUM(expected_count), 0) = 0 THEN 0\n           ELSE GREATEST(0, (SUM(expected_count) - SUM(actual_count)) * 100.0 / SUM(expected_count))\n         END,\n         2\n       ) AS synthetic_packet_loss_pct\nFROM expected;",
          "refId": "A"
        }
      ],
      "title": "Synthetic Packet Loss Approximation",
      "type": "stat"
    },
