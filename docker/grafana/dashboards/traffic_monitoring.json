          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(road_segment_id, sensor_id) AS intersection_id,\n       payload ->> 'current_phase' AS current_phase,\n       ROUND(AVG((payload ->> 'vehicle_count')::numeric), 2) AS avg_vehicle_count,\n       ROUND(AVG((payload ->> 'remaining_time_sec')::numeric), 2) AS avg_remaining_time_sec,\n       BOOL_OR((payload ->> 'pedestrian_request')::boolean) AS any_pedestrian_request\nFROM sensor_readings\nWHERE sensor_type = 'traffic_light'\n  AND $__timeFilter(recorded_at)\nGROUP BY COALESCE(road_segment_id, sensor_id), payload ->> 'current_phase'\nORDER BY intersection_id, current_phase;",
          "refId": "A"
        }
