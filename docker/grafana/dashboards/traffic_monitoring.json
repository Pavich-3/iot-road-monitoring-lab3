          "rawSql": "SELECT COALESCE(road_segment_id, sensor_id) AS intersection_id,\n       ROUND(AVG((payload ->> 'vehicle_count')::numeric), 2) AS avg_vehicle_count\nFROM sensor_readings\nWHERE sensor_type = 'traffic_light'\n  AND $__timeFilter(recorded_at)\nGROUP BY COALESCE(road_segment_id, sensor_id)\nORDER BY intersection_id;",
          "refId": "A"
