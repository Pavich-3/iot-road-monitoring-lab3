        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-road-monitoring"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  AVG(\n    CASE\n      WHEN (payload ->> 'pm2_5')::numeric <= 12 THEN 50\n      WHEN (payload ->> 'pm2_5')::numeric <= 35.4 THEN 100\n      WHEN (payload ->> 'pm2_5')::numeric <= 55.4 THEN 150\n      WHEN (payload ->> 'pm2_5')::numeric <= 150.4 THEN 200\n      ELSE 300\n    END\n  )::numeric AS air_quality_index\nFROM sensor_readings\nWHERE sensor_type = 'environmental'\n  AND $__timeFilter(created_at)\nGROUP BY time\nORDER BY time;",
          "refId": "A"
        }
      ],
      "title": "Air Quality Index",
      "type": "timeseries"
    }
